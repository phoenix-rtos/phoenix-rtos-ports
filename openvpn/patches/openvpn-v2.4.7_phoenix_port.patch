                 add_route_connected_v6_net(tt, es);
             }
         }
+#elif defined(TARGET_PHOENIX)
+		{
+			if (tun) {
+				argv_printf(&argv,
+                        "%s %s %s pointopoint %s mtu %d",
+                        IFCONFIG_PATH,
+                        tt->actual_name,
+                        ifconfig_local,
+                        ifconfig_remote_netmask,
+                        tun_mtu
+                        );
+			}
+			else {
+				argv_printf(&argv,
+                        "%s %s %s netmask %s mtu %d",
+                        IFCONFIG_PATH,
+                        tt->actual_name,
+                        ifconfig_local,
+                        ifconfig_remote_netmask,
+                        tun_mtu
+                        );
+			}
