 int
 vroute_doaddr(struct iked *env, char *ifname, struct sockaddr *addr,
     struct sockaddr *mask, int add)
 {
+#if defined(__phoenix__)
+	struct iked_vroute_sc	*ivr = env->sc_vroute;
+	struct ifreq		 req;
+	unsigned long		 ioreq;
+	int			 af;
+	char			 addr_buf[NI_MAXHOST];
+	char			 mask_buf[NI_MAXHOST];
+
+	/* cache iface name for later use in routing table operations */
+	strncpy(ivr->ifname, ifname, sizeof(ivr->ifname));
+
+	/* NOTE: we don't support alias addresses for interfaces - this implementation sets the main one */
+	af = addr->sa_family;
+	switch (af) {
+	case AF_INET:
+		bzero(&req, sizeof(req));
+		strncpy(req.ifr_name, ifname, sizeof(req.ifr_name));
+
+		inet_ntop(af, &((struct sockaddr_in *)addr)->sin_addr,
+		    addr_buf, sizeof(addr_buf));
+		inet_ntop(af, &((struct sockaddr_in *)mask)->sin_addr,
+		    mask_buf, sizeof(mask_buf));
+		log_debug("%s: %s inet %s netmask %s", __func__,
+		    add ? "add" : "del",addr_buf, mask_buf);
+
+		/* we need to send 2 separate ioctls for address and netmask */
+		if (add) {
+			ioreq = SIOCSIFADDR;
+			memcpy(&req.ifr_addr, addr, sizeof(req.ifr_addr));
+			if (ioctl(ivr->ivr_iosock, ioreq, &req) == -1) {
+				log_warn("%s: req: %lu", __func__, ioreq);
+				return (-1);
+			}
+
+			ioreq = SIOCSIFNETMASK;
+			memcpy(&req.ifr_netmask, mask, sizeof(req.ifr_netmask));
+			if (ioctl(ivr->ivr_iosock, ioreq, &req) == -1) {
+				log_warn("%s: req: %lu", __func__, ioreq);
+				return (-1);
+			}
+		} else {
+			/* set IP address to 0.0.0.0 */
+			ioreq = SIOCSIFADDR;
+			memset(&req.ifr_addr, 0, sizeof(req.ifr_addr));
+			if (ioctl(ivr->ivr_iosock, ioreq, &req) == -1) {
+				log_warn("%s: req: %lu", __func__, ioreq);
+				return (-1);
+			}
+		}
+		break;
+	case AF_INET6:
+		log_warn("%s: IPv6 support is not implemented", __func__);
+		return (-1);
+	default:
+		return (-1);
+	}
+#else
 	struct iked_vroute_sc	*ivr = env->sc_vroute;
 	struct ifaliasreq	 req;
 	struct in6_aliasreq	 req6;
@@ -613,5 +776,6 @@
 		return (-1);
 	}
 
+#endif /* __phoenix__ */
 	return (0);
 }
