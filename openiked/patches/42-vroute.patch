 int
 vroute_doroute(struct iked *env, int flags, int addrs, int rdomain, uint8_t type,
     struct sockaddr *dest, struct sockaddr *mask, struct sockaddr *addr, int *need_gw)
 {
+#if defined(__phoenix__)
+	struct iked_vroute_sc	*ivr = env->sc_vroute;
+	struct rtentry rt = { 0 };
+
+	/* FIXME: RTM_GET not implemented */
+
+	/*
+	 * Phoenix-RTOS requires RTA_NETMASK for all route operations.
+	 * Routes with only RTA_DST (e.g. clone route to peer) are not
+	 * supported and not needed — skip silently.
+	 */
+	if (!(addrs & RTA_NETMASK)) {
+		log_debug("%s: skipping route without netmask (not needed on phoenix)",
+		    __func__);
+		return (0);
+	}
+
+
+	{ // debug
+		char addr_buf[NI_MAXHOST] = "NULL";
+		char dest_buf[NI_MAXHOST] = "NULL";
+		char mask_buf[NI_MAXHOST] = "NULL";
+
+		inet_ntop(dest->sa_family, &((struct sockaddr_in *)dest)->sin_addr,
+		    dest_buf, sizeof(dest_buf));
+
+		if (addrs & RTA_GATEWAY)
+			inet_ntop(addr->sa_family, &((struct sockaddr_in *)addr)->sin_addr,
+			    addr_buf, sizeof(addr_buf));
+
+		if (addrs & RTA_NETMASK)
+			inet_ntop(mask->sa_family, &((struct sockaddr_in *)mask)->sin_addr,
+			    mask_buf, sizeof(mask_buf));
+
+		log_debug("%s: %s ROUTE DST: %s netmask %s GW: %s DEV: %s", __func__,
+				type == RTM_ADD ? "add" : "del", dest_buf, mask_buf, addr_buf, ivr->ifname);
+	}
+
+	/* NOTE: for phoenix rt_dev is required (we have netif-based routing */
+	rt.rt_dev = ivr->ifname;
+
+	rt.rt_flags = flags;
+	rt.rt_dst = *dest;
+
+	if (addrs & RTA_NETMASK)
+		rt.rt_genmask = *mask;
+
+	if (addrs & RTA_GATEWAY)
+		rt.rt_gateway = *addr;
+
+	rt.rt_metric = 100;
+
+	long ioreq = type == RTM_ADD ? SIOCADDRT : SIOCDELRT;
+	if (ioctl(ivr->ivr_iosock, ioreq, &rt) == -1) {
+		log_warn("%s: req: %lu", __func__, ioreq);
+		return (-1);
+	}
+
+
+#else
 	struct vroute_msg	 m_rtmsg;
 	struct iovec		 iov[7];
 	struct iked_vroute_sc	*ivr = env->sc_vroute;
@@ -371,9 +473,9 @@
 
 	if (rtm.rtm_addrs & RTA_DST) {
 		iov[iovcnt].iov_base = dest;
-		iov[iovcnt].iov_len = dest->sa_len;
+		iov[iovcnt].iov_len = SA_LEN(dest);
 		iovcnt++;
-		padlen = ROUNDUP(dest->sa_len) - dest->sa_len;
+		padlen = ROUNDUP(SA_LEN(dest)) - SA_LEN(dest);
 		if (padlen > 0) {
 			iov[iovcnt].iov_base = &pad;
 			iov[iovcnt].iov_len = padlen;
@@ -383,9 +485,9 @@
 
