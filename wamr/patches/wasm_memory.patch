+    /* mprotect fix */
+
+    if (os_mprotect(new_mem, new_size, MMAP_PROT_NONE) != 0 ||
+        os_mprotect(new_mem, commit_size, MMAP_PROT_READ | MMAP_PROT_WRITE) != 0) {
         wasm_munmap_linear_memory(new_mem, new_size, new_size);
         return NULL;
     }
