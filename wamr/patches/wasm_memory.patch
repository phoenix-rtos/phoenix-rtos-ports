+        new_mem = os_mmap(NULL, new_size, MMAP_PROT_READ | MMAP_PROT_WRITE, MMAP_MAP_NONE,
                           os_get_invalid_handle());
     }
     if (!new_mem) {
@@ -1517,8 +1518,10 @@ wasm_mremap_linear_memory(void *mapped_mem, uint64 old_size, uint64 new_size,
     }
 #endif
 
